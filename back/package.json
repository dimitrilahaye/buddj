{
  "name": "cb-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "tsc",
    "clean": "tsc --build --clean",
    "build": "rm -rf dist && tsc --build",
    "dev": "docker-compose up -d && tsx watch ./src",
    "start": "node dist/index.js",
    "vercel": "vercel --prod",
    "deploy": "sh scripts/deploy.sh",
    "db": "npx typeorm-ts-node-esm -d ./src/providers/persistence/typeormConfig.ts",
    "dbt": "npx typeorm-ts-node-esm -t ./src/providers/persistence/typeormConfig.ts",
    "db:generate": "npm run db -- migration:generate ./src/providers/persistence/migrations/$npm_config_name",
    "db:create": "npm run dbt -- migration:create ./src/providers/persistence/migrations/$npm_config_name",
    "db:migrate": "npm run db -- migration:run",
    "db:show": "npm run db -- migration:show",
    "db:revert": "npm run db -- migration:revert",
    "db:drop": "npm run db -- schema:drop",
    "db:log": "npm run db -- schema:log",
    "db:migrate:prod": "NODE_ENV=production npm run db:migrate",
    "db:prepare": "npm run db:drop && npm run db:migrate",
    "db:prepare:test": "NODE_ENV=test npm run db:prepare",
    "test": "NODE_ENV=test mocha --timeout 7000",
    "tu": "mocha --config .mocharc.unit.json",
    "ti": "mocha --config .mocharc.integration.json",
    "tf": "npm run db:prepare:test && npm run test"
  },
  "engines": {
    "node": "^24.14.1"
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cookie-session": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lodash": "^4.17.23",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^8.0.2",
    "@types/cookie-session": "^2.0.49",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/mocha": "^10.0.10",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.20.0",
    "@types/sinon": "^21.0.0",
    "@types/sinon-chai": "^3.2.12",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "chai": "^4.5.0",
    "chai-as-promised": "^8.0.2",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.4",
    "mocha": "^11.7.5",
    "sinon": "^21.0.3",
    "sinon-chai": "^3.7.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
